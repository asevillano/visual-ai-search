{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "webImageName": {
      "value": "${SERVICE_WEB_IMAGE_NAME}"
    },
    "searchSku": {
      "value": "${AZURE_SEARCH_SKU=standard}"
    },
    "searchIndexName": {
      "value": "${AZURE_SEARCH_INDEX_NAME=visual-search-index}"
    },
    "openaiEmbeddingDeployment": {
      "value": "${AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large}"
    },
    "openaiChatDeployment": {
      "value": "${AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1}"
    },
    "searchStrategy": {
      "value": "${SEARCH_STRATEGY=all}"
    }
  }
}
